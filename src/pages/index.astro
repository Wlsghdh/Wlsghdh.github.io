---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileHeader from '../components/ProfileHeader.astro';
import { site, activityCategories } from '../data/site';
import { education, experience, publications, projects, awards, skills } from '../data/cv';
---

<BaseLayout>
  <ProfileHeader slot="before-nav" />

  <!-- Publications -->
  <section id="publications" class="docs-section first-section">
    <h2 class="section-title">Publications</h2>
    {
      publications.map((pub) => (
        <div class="paper">
          <p class="title">[{pub.tag}] {pub.title}</p>
          <p class="authors">
            {pub.authors.map((a, i) => (
              <>
                {i > 0 && ', '}
                {a === site.authorKo ? <b class="me">{a}</b> : a}
              </>
            ))}
          </p>
          <p class="venue">
            <i>{pub.venue}</i>
          </p>
          <div class="paper-buttons">
            {pub.links.map((l) => (
              <a class="button" href={l.url} target="_blank" rel="noopener noreferrer">
                {l.label}
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </section>

  <!-- Projects -->
  <section id="projects" class="docs-section">
    <h2 class="section-title">Projects</h2>
    {
      projects.map((p) => (
        <div class="paper">
          <p class="title">
            {p.title}
            <b class="date-right">{p.period}</b>
          </p>
          {p.subtitle && <p class="muted small">{p.subtitle}</p>}
          <p class="summary">{p.summary}</p>
          <p class="stack small">{p.stack.join(' · ')}</p>
          <div class="paper-buttons">
            {p.links.map((l) => (
              <a class="button" href={l.url} target="_blank" rel="noopener noreferrer">
                {l.label}
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </section>

  <!-- Education -->
  <section id="education" class="docs-section">
    <h2 class="section-title">Education</h2>
    {
      education.map((e) => (
        <div class="paper">
          <p class="title">{e.school}</p>
          <p>
            {e.detail || ' '}
            <b class="date-right">{e.period}</b>
          </p>
        </div>
      ))
    }
  </section>

  <!-- Experience -->
  <section id="experience" class="docs-section">
    <h2 class="section-title">Experience</h2>
    {
      experience.map((e) => (
        <div class="paper">
          <p class="title">
            {e.title}
            <b class="date-right">{e.period}</b>
          </p>
          {e.org && <p class="muted">{e.org}</p>}
          {e.detail && <p class="summary">{e.detail}</p>}
        </div>
      ))
    }
  </section>

  <!-- Honors & Awards -->
  <section id="awards" class="docs-section">
    <h2 class="section-title">Honors &amp; Awards</h2>
    {
      awards.map((a) => (
        <div class="paper award">
          <p>
            <b>{a.title}</b>
            {a.org && <span class="muted"> — {a.org}</span>}
            <b class="date-right">{a.date}</b>
          </p>
        </div>
      ))
    }
  </section>

  <!-- Skills -->
  <section id="skills" class="docs-section">
    <h2 class="section-title">Skills</h2>
    {
      skills.map((s) => (
        <div class="paper skill">
          <p>
            <b class="skill-cat">{s.category}</b>
            <span class="muted">{s.items.join(' · ')}</span>
          </p>
        </div>
      ))
    }
  </section>

  <!-- Contact -->
  <section id="contact" class="docs-section">
    <h2 class="section-title">Contact</h2>
    <div class="paper">
      <p><b class="skill-cat">Email</b><a href={`mailto:${site.email}`}>{site.email}</a></p>
      <p>
        <b class="skill-cat">GitHub</b>
        <a href={site.github} target="_blank" rel="noopener noreferrer">github.com/{site.githubUsername}</a>
      </p>
      <p>
        <b class="skill-cat">Blog</b>
        <a href={site.blog} target="_blank" rel="noopener noreferrer">edu-data.tistory.com</a>
      </p>
    </div>
  </section>

  <!-- History line — 맨 아래 (내비 미포함) -->
  <section id="history" class="docs-section">
    <h2 class="section-title">History</h2>
    <div class="history-legend">
      {
        activityCategories.map((c) => (
          <span class="legend-item">
            <span class="legend-dot" style={`background:${c.color}`}></span>
            {c.label}
          </span>
        ))
      }
    </div>
    <div class="card history-placeholder">
      <p>🗓 History line — 날짜별 활동이 카테고리 색으로 표시될 자리입니다 (Phase 3).</p>
    </div>
  </section>
</BaseLayout>

<style>
  /* 내비 바로 아래 첫 섹션은 상단 보더 제거 (vvsjeon과 동일) */
  .first-section {
    border-top: 0;
  }

  .authors {
    color: var(--text);
  }
  .authors .me {
    color: var(--primary);
    font-weight: 600;
  }
  .venue {
    color: var(--text-muted);
  }
  .paper-buttons {
    margin-top: 6px;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .date-right {
    float: right;
    font-weight: 600;
    color: var(--text);
    margin-left: 1rem;
  }
  .muted {
    color: var(--text-muted);
  }
  .small {
    font-size: 0.875rem;
  }
  .summary {
    color: var(--text-muted);
    font-size: 0.9375rem;
    margin-top: 2px;
  }
  .stack {
    color: var(--text-faint);
    margin-top: 2px;
  }

  .award p,
  .skill p {
    overflow: hidden; /* float date 포함 */
  }
  .award {
    margin-bottom: 0.7rem;
  }
  .skill {
    margin-bottom: 0.45rem;
  }
  .skill-cat {
    display: inline-block;
    min-width: 9.5rem;
    font-weight: 600;
  }

  /* History */
  .history-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.1rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 3px;
    display: inline-block;
  }
  .history-placeholder {
    padding: 1.1rem 1.3rem;
    color: var(--text-muted);
    font-size: 0.9375rem;
  }

  @media (max-width: 640px) {
    .date-right {
      float: none;
      display: block;
      margin-left: 0;
      font-size: 0.875rem;
    }
    .skill-cat {
      display: block;
      min-width: 0;
    }
  }
</style>
