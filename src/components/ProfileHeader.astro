---
import { site } from '../data/site';
---

<section class="profile-header">
  <img
    class="headshot"
    src="/profile.jpg"
    alt={`${site.authorKo} 증명사진`}
    width="120"
    height="150"
    onerror="this.onerror=null;this.src='/profile-placeholder.svg'"
  />
  <div class="info">
    <h1 class="name">{site.authorKo} <span class="name-en mono">{site.authorEn}</span></h1>
    <p class="tagline">{site.tagline}</p>
    <p class="role">
      {site.role} <span class="role-period mono">{site.rolePeriod}</span>
    </p>
    <ul class="links">
      <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
      <li>
        <a href={site.github} target="_blank" rel="noopener noreferrer">github.com/{site.githubUsername}</a>
      </li>
      <li><a href={site.blog} target="_blank" rel="noopener noreferrer">edu-data.tistory.com</a></li>
      {
        site.scholar && (
          <li>
            <a href={site.scholar} target="_blank" rel="noopener noreferrer">
              Google Scholar
            </a>
          </li>
        )
      }
    </ul>
  </div>
</section>

<style>
  .profile-header {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    padding: 2.4rem 0 2.2rem;
  }

  .headshot {
    width: 120px;
    height: 150px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  /* 이름 — 한나체 Air + CAU Blue */
  .name {
    font-family: var(--font-display);
    font-size: var(--fs-name);
    font-weight: 400;
    color: var(--primary);
    line-height: 1.25;
  }
  .name-en {
    color: var(--text-faint);
    font-size: 0.55em;
    margin-left: 0.2rem;
  }

  .tagline {
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  .role {
    font-weight: 600;
    font-size: 0.9375rem;
    margin-top: 0.55rem;
  }
  .role-period {
    color: var(--text-faint);
    font-weight: 400;
    margin-left: 0.35rem;
  }

  .links {
    margin-top: 0.55rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.1rem;
    font-size: 0.875rem;
  }
  .links a {
    color: var(--text-muted);
  }
  .links a:hover {
    color: var(--primary);
  }

  @media (max-width: 640px) {
    .profile-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.1rem;
      padding-top: 1.6rem;
    }
    .headshot {
      width: 104px;
      height: 130px;
    }
  }
</style>
