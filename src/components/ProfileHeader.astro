---
import { site } from '../data/site';
---

<header class="header">
  <div class="header-photo">
    <a href="/">
      <img
        src="/profile.jpg"
        alt={`${site.authorKo} 사진`}
        width="170"
        height="213"
        onerror="this.onerror=null;this.src='/profile-placeholder.svg'"
      />
    </a>
  </div>
  <div class="header-desc">
    <h1>{site.authorKo} <span class="name-en">{site.authorEn}</span></h1>
    <p>{site.tagline}</p>
    <p class="email">{site.email.replace('@', '[at]')}</p>
    <p class="icons">
      <a href={site.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" title="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Zm8 3.2a7 7 0 0 0-2.21 13.64c.35.07.48-.15.48-.34v-1.19c-1.95.42-2.36-.94-2.36-.94-.32-.81-.78-1.03-.78-1.03-.63-.43.05-.42.05-.42.7.05 1.07.72 1.07.72.62 1.07 1.63.76 2.03.58.06-.45.24-.76.44-.93-1.55-.18-3.19-.78-3.19-3.46 0-.76.27-1.39.72-1.88-.07-.18-.31-.89.07-1.85 0 0 .59-.19 1.93.72a6.7 6.7 0 0 1 3.51 0c1.34-.91 1.93-.72 1.93-.72.38.96.14 1.67.07 1.85.45.49.72 1.12.72 1.88 0 2.69-1.64 3.28-3.2 3.45.25.22.47.64.47 1.29v1.91c0 .19.13.41.49.34A7 7 0 0 0 12 5.2Z"
          />
        </svg>
      </a>
      <a href={site.blog} target="_blank" rel="noopener noreferrer" aria-label="Blog" title="Blog">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Zm2.5 13.9a1.6 1.6 0 1 0 0 3.2 1.6 1.6 0 0 0 0-3.2ZM5 10.8v2.3a6 6 0 0 1 6 6h2.3A8.3 8.3 0 0 0 5 10.8ZM5 6.5v2.3c5.62 0 10.2 4.57 10.2 10.2h2.3c0-6.9-5.6-12.5-12.5-12.5Z"
          />
        </svg>
      </a>
      <a href={`mailto:${site.email}`} aria-label="Email" title="Email">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Zm1.8 5.5 5.63 4.5c.33.27.8.27 1.14 0l5.63-4.5a.68.68 0 0 0-.85-1.06L12 10.6 6.65 6.44a.68.68 0 1 0-.85 1.06Zm12.7 2.13-5.08 4.06a2.28 2.28 0 0 1-2.84 0L5.5 9.63v6.47c0 .38.3.68.68.68h11.64c.38 0 .68-.3.68-.68V9.63Z"
          />
        </svg>
      </a>
    </p>
  </div>
</header>

<style>
  /* vvsjeon .header — 사진(좌) + 이름·설명(우), 위아래 넉넉한 여백 */
  .header {
    display: flex;
    align-items: flex-start;
    gap: 2.4rem;
    padding: 5rem 0 5rem;
  }

  .header-photo {
    flex: 0 0 170px;
  }
  .header-photo img {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    display: block;
  }

  .header-desc h1 {
    font-size: var(--fs-name);
    font-weight: 300;
    line-height: 1.25;
    margin-bottom: 0.3rem;
  }
  .name-en {
    font-size: 0.55em;
    color: var(--text-faint);
    font-weight: 300;
    margin-left: 0.15rem;
  }
  .header-desc p {
    margin-bottom: 0.1rem;
  }
  .email {
    color: var(--text-muted);
  }

  .icons {
    margin-top: 0.6rem;
    display: flex;
    gap: 0.55rem;
  }
  .icons a {
    color: var(--icon);
  }
  .icons a:hover {
    color: var(--primary);
  }
  .icons svg {
    width: 34px;
    height: 34px;
    display: block;
  }

  @media (max-width: 640px) {
    .header {
      flex-direction: column;
      gap: 1.6rem;
      padding: 3rem 0 3rem;
    }
    .header-photo {
      flex-basis: auto;
      width: 140px;
    }
  }
</style>
