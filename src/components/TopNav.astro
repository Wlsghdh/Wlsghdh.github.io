---
import { navSections } from '../data/site';

const isHome = Astro.url.pathname === '/';
---

<nav class="navbar">
  <div class="navbar-inner">
    <ul class="navbar-list">
      {
        navSections.map((s) => (
          <li>
            <a class="navbar-link" href={isHome ? `#${s.id}` : `/#${s.id}`} data-section={s.id}>
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  /* vvsjeon .navbar — 얇은 상하 보더, 대문자 소형 링크, 스크롤 시 상단 고정 */
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .navbar-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 2rem;
  }
  .navbar-list {
    display: flex;
    align-items: center;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .navbar-list::-webkit-scrollbar {
    display: none;
  }
  .navbar-link {
    display: block;
    text-transform: uppercase;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2rem;
    line-height: 5.4rem;
    margin-right: 3.2rem;
    color: var(--text);
    white-space: nowrap;
  }
  .navbar-link:hover {
    color: var(--primary);
    text-decoration: none;
  }
  .navbar-link.active {
    color: var(--primary);
  }

  @media (max-width: 640px) {
    .navbar-inner {
      padding: 0 1.5rem;
    }
    .navbar-link {
      line-height: 4.4rem;
      margin-right: 2.2rem;
      letter-spacing: 0.12rem;
    }
  }
</style>

<script>
  // 스크롤 스파이 — 보이는 섹션의 내비 링크를 활성(CAU Blue) 처리
  const links = document.querySelectorAll<HTMLAnchorElement>('.navbar a[data-section]');
  if (links.length > 0 && location.pathname === '/') {
    const setActive = (id: string) => {
      links.forEach((a) => a.classList.toggle('active', a.dataset.section === id));
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      },
      { rootMargin: '-20% 0px -65% 0px' },
    );

    links.forEach((a) => {
      const el = document.getElementById(a.dataset.section!);
      if (el) observer.observe(el);
    });
  }
</script>
