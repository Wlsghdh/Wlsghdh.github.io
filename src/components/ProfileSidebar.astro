---
import { site, navSections } from '../data/site';

/** 홈('/')에서만 앵커 스크롤 스파이가 동작. 다른 페이지에선 '/#id'로 이동 */
const isHome = Astro.url.pathname === '/';
---

<div class="profile">
  <!-- 증명사진 스타일 헤드샷 (라운드). /public/profile.jpg 교체 시 자동 반영 -->
  <img
    class="headshot"
    src="/profile.jpg"
    alt={`${site.authorKo} 증명사진`}
    width="150"
    height="150"
    onerror="this.onerror=null;this.src='/profile-placeholder.svg'"
  />

  <h1 class="name"><a href="/">{site.authorKo}</a></h1>

  <p class="role">{site.role}</p>
  <p class="role-period mono">{site.rolePeriod}</p>

  <ul class="links">
    <li>
      <a href={`mailto:${site.email}`} aria-label="이메일">
        <span class="icon" aria-hidden="true">✉</span>{site.email}
      </a>
    </li>
    <li>
      <a href={site.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <span class="icon" aria-hidden="true">⌥</span>github.com/{site.githubUsername}
      </a>
    </li>
    {
      site.scholar && (
        <li>
          <a href={site.scholar} target="_blank" rel="noopener noreferrer" aria-label="Google Scholar">
            <span class="icon" aria-hidden="true">🎓</span>Google Scholar
          </a>
        </li>
      )
    }
  </ul>

  <nav class="anchor-nav" aria-label="섹션 내비게이션">
    <ul>
      {
        navSections.map((s) => (
          <li>
            <a href={isHome ? `#${s.id}` : `/#${s.id}`} data-section={s.id}>
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<style>
  .profile {
    position: sticky;
    top: 3.5rem;
  }

  .headshot {
    width: 150px;
    height: 150px;
    object-fit: cover;
    border-radius: 14px;
    border: 1px solid var(--border);
    display: block;
  }

  /* 이름 — 한나체 Air + CAU Blue (이름/로고에만 사용) */
  .name {
    font-family: var(--font-display);
    font-size: var(--fs-name);
    font-weight: 400;
    color: var(--primary);
    line-height: 1.3;
    margin-top: 1.1rem;
  }
  .name a {
    color: inherit;
  }
  .name a:hover {
    text-decoration: none;
    color: var(--primary-hover);
  }

  .role {
    color: var(--text);
    font-weight: 600;
    font-size: 0.9375rem;
    margin-top: 0.35rem;
  }
  .role-period {
    color: var(--text-faint);
    margin-top: 0.15rem;
  }

  .links {
    margin-top: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-size: 0.875rem;
  }
  .links a {
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    word-break: break-all;
  }
  .links a:hover {
    color: var(--primary);
  }
  .links .icon {
    color: var(--text-faint);
    width: 1em;
    text-align: center;
    flex-shrink: 0;
  }

  /* 앵커 내비 — 활성 항목만 CAU Blue */
  .anchor-nav {
    margin-top: 1.6rem;
    padding-top: 1.3rem;
    border-top: 1px solid var(--hairline);
  }
  .anchor-nav ul {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .anchor-nav a {
    display: block;
    padding: 0.28rem 0.6rem;
    border-left: 2px solid transparent;
    border-radius: 0 6px 6px 0;
    color: var(--text-muted);
    font-size: 0.875rem;
    transition:
      color var(--transition),
      border-color var(--transition),
      background-color var(--transition);
  }
  .anchor-nav a:hover {
    color: var(--primary);
    background: var(--accent-soft);
    text-decoration: none;
  }
  .anchor-nav a.active {
    color: var(--primary);
    font-weight: 600;
    border-left-color: var(--primary);
    background: var(--accent-soft);
  }

  /* 모바일: 사이드바 sticky 해제, 사진 축소 */
  @media (max-width: 900px) {
    .profile {
      position: static;
    }
    .headshot {
      width: 110px;
      height: 110px;
    }
    .anchor-nav ul {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.25rem;
    }
    .anchor-nav a,
    .anchor-nav a.active {
      border-left: none;
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 0.15rem 0.7rem;
    }
    .anchor-nav a.active {
      border-color: var(--primary);
    }
  }
</style>

<script>
  // 스크롤 스파이 — 보이는 섹션의 앵커 메뉴를 활성(CAU Blue) 처리
  const links = document.querySelectorAll<HTMLAnchorElement>('.anchor-nav a[data-section]');
  if (links.length > 0 && location.pathname === '/') {
    const byId = new Map<string, HTMLAnchorElement>();
    links.forEach((a) => byId.set(a.dataset.section!, a));

    const setActive = (id: string) => {
      links.forEach((a) => a.classList.toggle('active', a.dataset.section === id));
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      },
      { rootMargin: '-15% 0px -70% 0px' },
    );

    byId.forEach((_, id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }
</script>
